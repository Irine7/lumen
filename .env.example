# Testnet scripts require STELLAR_NETWORK=testnet.
STELLAR_NETWORK=testnet

# STELLAR_SOURCE_ACCOUNT must be a local Stellar CLI key name from `stellar keys ls`.
# Do not put a secret key here.
STELLAR_SOURCE_ACCOUNT=admin

# Required for relayer-backed browser e2e scripts.
LUMEN_TESTNET_RELAYER_ENABLED=true

NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_CAMPAIGN_CONTRACT_ID=
NEXT_PUBLIC_VERIFIER_CONTRACT_ID=
NEXT_PUBLIC_MOCK_TOKEN_CONTRACT_ID=
OPERATOR_SECRET_KEY=

{
  "name": "lumen-aid",
  "private": true,
  "version": "0.1.0",
  "description": "Lumen - private aid rails on Stellar.",
  "packageManager": "pnpm@9.7.0",
  "scripts": {
    "dev": "pnpm --filter @lumen-aid/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm zk:test && pnpm -r --workspace-concurrency=1 test",
    "zk:doctor": "tsx circuits/claim/scripts/doctor.ts",
    "zk:setup": "tsx circuits/claim/scripts/setup.ts",
    "zk:clean": "tsx circuits/claim/scripts/clean.ts",
    "zk:build": "tsx circuits/claim/scripts/build.ts",
    "zk:build:dev": "tsx circuits/claim/scripts/build-dev.ts",
    "zk:proof:path": "tsx circuits/claim/scripts/proof-path.ts",
    "zk:prove:demo": "tsx circuits/claim/scripts/prove-demo.ts",
    "zk:verify:local": "tsx circuits/claim/scripts/verify-local.ts",
    "zk:verify:compliance": "tsx circuits/claim/scripts/verify-compliance.ts",
    "zk:test": "vitest run circuits/claim/scripts/zk.test.ts",
    "web:zk:prepare": "tsx scripts/web-zk-prepare.ts",
    "web:zk:clean": "tsx scripts/web-zk-clean.ts",
    "web:e2e:testnet": "tsx scripts/web-e2e-testnet.ts",
    "web:e2e:payout:testnet": "tsx scripts/web-e2e-payout-testnet.ts",
    "web:e2e:compliance:testnet": "tsx scripts/web-e2e-compliance-testnet.ts",
    "judge:validate:testnet": "tsx scripts/judge-validate-testnet.ts",
    "judge:prepare-demo:testnet": "tsx scripts/judge-prepare-demo-testnet.ts",
    "privacy:audit": "tsx scripts/privacy-audit.ts",
    "demo:e2e": "tsx scripts/demo-e2e.ts",
    "stellar:doctor": "tsx scripts/stellar-doctor.ts",
    "stellar:asset:doctor:testnet": "tsx scripts/stellar-asset-doctor-testnet.ts",
    "stellar:asset:setup-aidusd:testnet": "tsx scripts/stellar-asset-setup-aidusd-testnet.ts",
    "stellar:read:testnet": "tsx scripts/stellar-read-testnet.ts",
    "stellar:fresh-campaign:testnet": "tsx scripts/stellar-fresh-campaign-testnet.ts",
    "stellar:fresh-payout-campaign:testnet": "tsx scripts/stellar-fresh-payout-campaign-testnet.ts",
    "stellar:fresh-aidusd-campaign:testnet": "tsx scripts/stellar-fresh-aidusd-campaign-testnet.ts",
    "stellar:active:testnet": "tsx scripts/stellar-active-testnet.ts",
    "stellar:payout:active:testnet": "tsx scripts/stellar-payout-active-testnet.ts",
    "stellar:aidusd:active:testnet": "tsx scripts/stellar-aidusd-active-testnet.ts",
    "stellar:smoke:testnet:full": "tsx scripts/stellar-smoke-testnet-full.ts",
    "stellar:smoke:payout:testnet": "tsx scripts/stellar-smoke-payout-testnet.ts",
    "stellar:smoke:aidusd:testnet": "tsx scripts/stellar-smoke-aidusd-testnet.ts",
    "stellar:smoke:compliance:testnet": "tsx scripts/stellar-smoke-compliance-testnet.ts",
    "contracts:build": "tsx scripts/contracts-build.ts",
    "contracts:generate-verifier": "tsx scripts/generate-soroban-verifier.ts",
    "stellar:deploy:testnet": "tsx scripts/stellar-deploy-testnet.ts",
    "stellar:init-campaign:testnet": "tsx scripts/stellar-init-campaign-testnet.ts",
    "stellar:claim:alice:testnet": "tsx scripts/stellar-claim-alice-testnet.ts",
    "stellar:claim:bob:testnet": "tsx scripts/stellar-claim-bob-testnet.ts",
    "stellar:claim:alice-duplicate:testnet": "tsx scripts/stellar-claim-alice-duplicate-testnet.ts",
    "contracts:test": "cargo test -p lumen_verifier && cargo test -p lumen_campaign && cargo test -p lumen_mock_token",
    "contracts:test:compliance": "pnpm contracts:test",
    "contracts:test:dev": "cargo test -p lumen_verifier --features dev_verifier && cargo test -p lumen_campaign --features dev_verifier && cargo test -p lumen_mock_token"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/node": "^24.0.10",
    "@types/snarkjs": "^0.7.9",
    "circomlib": "^2.0.5",
    "dotenv": "^17.4.2",
    "snarkjs": "^0.7.6",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
